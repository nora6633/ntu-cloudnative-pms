# These mirror the env vars injected in production exactly
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/pms
SPRING_DATASOURCE_USERNAME=appuser
SPRING_DATASOURCE_PASSWORD=apppass
JWT_SECRET=
CORS_ALLOWED_ORIGINS=http://localhost:5173 # Frontend dev server URL 
VITE_API_URL=http://localhost:8080/api # Backend API URL for frontend dev server

# Set to "prod" to test the production Spring profile locally
SPRING_PROFILES_ACTIVE=

# Devcontainer only — MySQL root password, not used in production
DB_ROOT_PASSWORD=rootpass