# ─── Backend env vars ───────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/pms
SPRING_DATASOURCE_USERNAME=appuser
SPRING_DATASOURCE_PASSWORD=apppass
JWT_SECRET=
SERVER_PORT=8080
# Dev only — allows the Vite dev server to call the backend cross-origin.
# Not needed on Railway: the nginx proxy makes all browser requests same-origin.
CORS_ALLOWED_ORIGINS=http://localhost:${VITE_PORT}

# ─── Frontend env vars  ──────────────────
VITE_PORT=5173
# In production, set to /api so requests are proxied through nginx (same-origin).
# In dev, set to the full backend URL (e.g. http://localhost:8080/api).
VITE_API_URL=http://localhost:${SERVER_PORT}/api

# Railway internal networking URL of the backend service
# nginx uses this to proxy /api/* requests to the backend without going over the public internet.
BACKEND_URL=

# ─── Dev / local overrides ────────────────────────────────────────────────────
# Set to "prod" to test the production Spring profile locally
SPRING_PROFILES_ACTIVE=

# Devcontainer only — MySQL root password, not used in production
DB_ROOT_PASSWORD=rootpass